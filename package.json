{
	"name": "oho-clone",
	"version": "0.1.0",
	"private": true,
	"packageManager": "bun@1.3.9",
	"description": "Omnichannel chat aggregation platform — oho.chat clone",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"check": "turbo typecheck && bunx biome check",
		"format": "bunx biome check --write .",
		"test": "turbo test",
		"db:generate": "bun run --filter @oho/db db:generate",
		"db:push": "bun run --filter @oho/db db:push",
		"db:seed": "bun run --filter @oho/db db:seed",
		"db:studio": "bun run --filter @oho/db db:studio",
		"docker:up": "docker compose up -d",
		"docker:down": "docker compose down",
		"docker:logs": "docker compose logs -f",
		"docker:app": "docker compose --profile app up -d --build",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"husky": "^9.1.0",
		"lint-staged": "^15.3.0",
		"turbo": "^2.4.0",
		"typescript": "^5.9.0"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css}": [
			"bunx biome check --write --unsafe"
		]
	},
	"dependencies": {
		"@types/node": "^25.3.5",
		"socket.io": "^4.8.3"
	}
}
